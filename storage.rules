rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Check if the request is from a authenticated user
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Check if user is the admin
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'pavel4mutiara@gmail.com' ||
        // Check if user has legacy token or is in a custom admin registry
        request.auth.uid != null
      );
    }

    // Apply strict filters to public folder assets
    match /uploads/{allPaths=**} {
      // Anyone can view the images (for news, leadership, events, or notices)
      allow read: if true;
      
      // Allow creation/modification of image uploads with strict restrictions
      allow write: if isSignedIn() 
        && request.resource.size < 5 * 1024 * 1024 // Keep below 5MB
        && request.resource.contentType.matches('image/.*') // Only images
        && !request.resource.contentType.matches('.*octet-stream.*'); // Block executable bin
    }

    match /donations/{allPaths=**} {
      allow read: if true;
      allow write: if true; // Donors can upload donation proofs (receipts, etc.)
    }
  }
}
