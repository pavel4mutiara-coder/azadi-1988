# Azadi Social Welfare Organization App Configuration

# 1. Google ReCAPTCHA Enterprise Site Key (Required for Firebase App Check in Production)
VITE_RECAPTCHA_SITE_KEY=

# 2. Super Administrator Configuration (Optional, defaults to pavel4mutiara@gmail.com)
VITE_SUPERADMIN_EMAIL=pavel4mutiara@gmail.com

# Note: The application's core Firebase connection parameters (projectId, appId, apiKey, authDomain, storageBucket)
# are automatically parsed from the `firebase-applet-config.json` file in the root directory.
